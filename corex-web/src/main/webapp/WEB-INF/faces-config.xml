<?xml version="1.0" encoding="UTF-8"?>
<faces-config
    xmlns="http://java.sun.com/xml/ns/javaee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://java.sun.com/xml/ns/javaee 
    http://java.sun.com/xml/ns/javaee/web-facesconfig_2_0.xsd"
    version="2.0">
  	
    <!-- Custom Exception Handler Factory for handling view state restoration errors -->
    <factory>
        <exception-handler-factory>
            com.web.coretix.customhandlers.CustomExceptionHandlerFactory
        </exception-handler-factory>
    </factory>

    <!-- JSF and Spring are integrated -->
    <application>
        <resource-bundle>
            <base-name>messages</base-name>
            <var>msg</var>
        </resource-bundle>
        <locale-config>
            <default-locale>en</default-locale>
            <supported-locale>es</supported-locale>
            <supported-locale>fr</supported-locale>
            <supported-locale>malay</supported-locale>
            <supported-locale>ur</supported-locale>
            <supported-locale>ta</supported-locale>
            <supported-locale>chinese</supported-locale>
        </locale-config>
        <el-resolver>
            org.springframework.web.jsf.el.SpringBeanFacesELResolver
        </el-resolver>
    </application>

    <name>primefaces_avalon</name>

    <component>
        <component-type>com.web.coretix.component.AvalonMenu</component-type>
        <component-class>com.web.coretix.component.AvalonMenu</component-class>
    </component>

    <render-kit>
        <renderer>
            <component-family>com.web.coretix.component</component-family>
            <renderer-type>com.web.coretix.component.AvalonMenuRenderer</renderer-type>
            <renderer-class>com.web.coretix.component.AvalonMenuRenderer</renderer-class>
        </renderer>
    </render-kit>
    
    <navigation-rule>
        <description>navigation Rule for login page</description>
        <navigation-case>
            <from-outcome>loginpage</from-outcome>
           <to-view-id>/login2.xhtml</to-view-id>
            <redirect />
        </navigation-case>
        <navigation-case>
            <from-outcome>login</from-outcome>
            <to-view-id>/login.xhtml</to-view-id>
            <redirect />
        </navigation-case>
        <navigation-case>
            <from-outcome>homepage</from-outcome>
            <to-view-id>/pages/home/homePage.xhtml</to-view-id>
            <redirect />
        </navigation-case>
        <navigation-case>
            <from-outcome>session_expired</from-outcome>
            <to-view-id>/login2.xhtml</to-view-id>
            <redirect />
        </navigation-case>
    </navigation-rule>

</faces-config>
